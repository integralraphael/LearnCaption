{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "learncaption",
  "version": "0.1.0",
  "identifier": "com.raphael.learncaption",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LearnCaption",
        "width": 900,
        "height": 620,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/ecdict.db"],
    "externalBin": ["binaries/audio-capture"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
